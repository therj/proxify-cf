# -----------------------------------------------------------------------------
# Template — copy to wrangler.toml and replace placeholders.
#   cp wrangler.toml.example wrangler.toml
#
# Commit policy: wrangler.toml often holds account/database/KV IDs and hostnames.
# For public repos, prefer env (e.g. CLOUDFLARE_ACCOUNT_ID) or keep wrangler.toml
# private / local-only; never commit secrets — use `wrangler secret put KEK`.
# -----------------------------------------------------------------------------

name = "proxify-cf"
main = "src/index.ts"
compatibility_date = "2026-04-30"
compatibility_flags = ["nodejs_compat"]

# *.workers.dev preview URLs; set workers_dev = false if you rely only on custom routes.
preview_urls = true
workers_dev = true

# Optional but recommended for CI / clarity (else use CLOUDFLARE_ACCOUNT_ID env):
# account_id = "00000000000000000000000000000000"

# -----------------------------------------------------------------------------
# Routes — omit entirely for workers.dev-only; add one [[routes]] block per rule.
#
# Custom domain (Worker is the origin / SSL terminates at Cloudflare):
# [[routes]]
# pattern = "proxy.example.com"
# custom_domain = true
#
# Hostname on an existing zone (Worker in front of another origin):
# [[routes]]
# pattern = "app.example.com"
# zone_name = "example.com"
# -----------------------------------------------------------------------------

# [[routes]]
# pattern = "proxy.example.com"
# custom_domain = true

# [[routes]]
# pattern = "origin-host.example.com"
# zone_name = "example.com"

# -----------------------------------------------------------------------------
# D1 — database_name must match `wrangler d1 create <name>`.
# database_id: output of `wrangler d1 create` or Dashboard → D1 → database UUID.
# Local dev uses Miniflare; remote deploy needs the real UUID.
# -----------------------------------------------------------------------------
[[d1_databases]]
binding = "DB"
database_name = "proxify-db"
database_id = "00000000-0000-4000-8000-000000000000"
migrations_dir = "./migrations"

# -----------------------------------------------------------------------------
# KV — binding name must match Worker env (see src/env.ts).
# id: output of `wrangler kv namespace create <label>` or Dashboard.
# -----------------------------------------------------------------------------
[[kv_namespaces]]
binding = "proxify_cache"
id = "00000000000000000000000000000000"

# -----------------------------------------------------------------------------
# Plain vars (non-secret). CF_ACCESS_* for Cloudflare Access JWT verification.
# KEK is NOT set here — use `wrangler secret put KEK` in production.
# -----------------------------------------------------------------------------
[vars]
CF_ACCESS_TEAM_DOMAIN = ""
CF_ACCESS_AUD = ""
LOCAL_ADMIN_EMAIL = ""

# -----------------------------------------------------------------------------
# Static assets: admin SPA build output (pnpm build / predeploy from repo root).
# -----------------------------------------------------------------------------
[assets]
directory = "../admin/dist"
binding = "ASSETS"
run_worker_first = true
not_found_handling = "single-page-application"
