{
  "name": "worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "db:migrate:local": "wrangler d1 migrations apply proxify_demo-db --local --env dev",
    "db:migrate:local:production": "wrangler d1 migrations apply proxify-db --local --env production",
    "db:migrate:remote:dev": "wrangler d1 migrations apply proxify_demo-db --remote --env dev",
    "db:migrate:remote": "wrangler d1 migrations apply proxify-db --remote --env production",
    "db:export:remote:dev": "node ../../scripts/d1-tooling.mjs export --env dev",
    "db:export:remote:production": "node ../../scripts/d1-tooling.mjs export --env production",
    "db:filter:dump": "node ../../scripts/filter-d1-dump.mjs",
    "db:import:local:dev": "node ../../scripts/d1-tooling.mjs import-local --env dev",
    "db:import:local:production": "node ../../scripts/d1-tooling.mjs import-local --env production",
    "db:pull:remote": "node ../../scripts/d1-tooling.mjs pull-remote",
    "dev": "wrangler dev --env dev",
    "dev:production": "wrangler dev --env production",
    "deploy": "wrangler deploy --env production",
    "deploy:dev": "wrangler deploy --env dev",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@proxify-cf/shared": "workspace:*",
    "hono": "^4.12.16",
    "jose": "^6.2.3",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260430.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  }
}
