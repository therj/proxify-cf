{
  "name": "worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "db:migrate:local": "wrangler d1 migrations apply proxify-db --local",
    "db:pull:remote": "wrangler d1 export proxify-db --remote --no-schema --output .remote-d1-data.raw.sql && node ../../scripts/filter-d1-export.cjs && wrangler d1 execute proxify-db --local --file .remote-d1-data.sql --yes",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@proxify-cf/shared": "workspace:*",
    "hono": "^4.12.16",
    "jose": "^6.2.3",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260430.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.86.0"
  }
}
